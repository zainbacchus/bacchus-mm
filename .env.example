# Copy to .env (gitignored). Never commit real values.
#
# Get keys from your Kalshi account settings:
#   demo: https://demo.kalshi.co  -> account -> API keys
#   prod: https://kalshi.com      -> account -> API keys
# The key generation flow gives you a key ID and downloads an RSA private key
# (.pem / .key file). Store the key file outside the repo or under data/
# (both are gitignored), chmod 600.

KALSHI_ENV=demo
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-demo-private-key.pem
